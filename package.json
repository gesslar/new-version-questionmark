{
  "name": "new-version-questionmark",
  "version": "1.6.2",
  "description": "Automatic version difference detection action for GitHub.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.js -o action",
    "update": "npx npm-check-updates -u && npm install",
